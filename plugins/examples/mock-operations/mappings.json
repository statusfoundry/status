{
  "resources": [
    {
      "type": "service",
      "request": "fetch_status",
      "source": "$.services[*]",
      "id": "{{item.id}}",
      "name": "{{item.name}}",
      "fields": {
        "state": "{{item.state}}",
        "region": "{{item.region}}"
      },
      "actionUrl": "{{item.dashboardUrl}}"
    }
  ],
  "events": [
    {
      "type": "mock.service.degraded",
      "request": "fetch_status",
      "source": "$.services[*]",
      "when": {
        "field": "state",
        "operator": "changed_to",
        "value": "degraded"
      },
      "resourceId": "{{item.id}}",
      "title": "{{item.name}} degraded",
      "summary": "{{item.name}} is degraded in {{item.region}}.",
      "severity": "warning",
      "actionUrl": "{{item.dashboardUrl}}"
    },
    {
      "type": "mock.service.recovered",
      "request": "fetch_status",
      "source": "$.services[*]",
      "when": {
        "field": "state",
        "operator": "changed_to",
        "value": "healthy"
      },
      "resourceId": "{{item.id}}",
      "title": "{{item.name}} recovered",
      "summary": "{{item.name}} is healthy again.",
      "severity": "ok",
      "actionUrl": "{{item.dashboardUrl}}"
    },
    {
      "type": "mock.error_rate.high",
      "request": "fetch_status",
      "source": "$.services[*]",
      "when": "$.errorRatePercent >= 5",
      "resourceId": "{{item.id}}",
      "title": "{{item.name}} error rate high",
      "summary": "{{item.name}} is returning errors for {{item.errorRatePercent}}% of requests.",
      "severity": "critical",
      "actionUrl": "{{item.dashboardUrl}}"
    }
  ],
  "metrics": [
    {
      "request": "fetch_status",
      "source": "$.services[*]",
      "name": "error_rate_percent",
      "resourceId": "{{item.id}}",
      "value": "$.errorRatePercent",
      "unit": "%"
    }
  ]
}
