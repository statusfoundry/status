{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugins.status.app/schemas/plugin/v1/auth.schema.json",
  "title": "Status plugin auth definition (auth.json)",
  "description": "Declares how the plugin authenticates. The app renders the setup form from `fields` and stores secrets in Keychain. Plugins never access Keychain directly.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type"],
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "oauth2" } },
        "required": ["type"]
      },
      "then": {
        "required": ["provider", "applicationId", "oauth2"]
      }
    }
  ],
  "properties": {
    "type": {
      "description": "Auth mechanism. `oauth2` uses an app-owned native authorization-code + PKCE flow; plugins declare public provider metadata only.",
      "enum": ["none", "api-key", "bearer-token", "basic-auth", "oauth2", "jwt-api-key", "private-key-jwt"]
    },
    "fields": {
      "type": "array",
      "description": "Credential fields the user must provide during setup.",
      "items": { "$ref": "#/$defs/field" }
    },
    "placement": {
      "$ref": "#/$defs/placement",
      "description": "Where the request engine injects the credential. Currently used by api-key auth."
    },
    "provider": {
      "type": "string",
      "description": "Provider slug for the upstream service (for example github, gitlab, jira). Used to match OAuth registrations and documentation.",
      "pattern": "^[a-z][a-z0-9-]*$",
      "examples": ["github", "gitlab", "jira", "appstoreconnect"]
    },
    "applicationId": {
      "type": "string",
      "description": "Public provider application identifier bundled with the plugin. For OAuth plugins this is the client ID registered with the provider. Secrets never belong in the plugin package.",
      "minLength": 1,
      "maxLength": 200
    },
    "oauth2": {
      "$ref": "#/$defs/oauth2",
      "description": "OAuth provider endpoints and scopes for native authorization-code + PKCE. Required when type is oauth2."
    }
  },
  "$defs": {
    "oauth2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorizationUrl", "tokenUrl", "redirectUri"],
      "properties": {
        "authorizationUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "tokenUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "redirectUri": {
          "type": "string",
          "minLength": 1,
          "pattern": "^status://oauth/[a-z][a-z0-9-]*$"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "additionalAuthorizationParameters": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in", "name"],
      "properties": {
        "in": {
          "type": "string",
          "enum": ["header"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "type"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "description": "How the app renders and stores the field. `secret` and `secret-file` values go to Keychain.",
          "enum": ["text", "secret", "secret-file", "url"]
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "placeholder": {
          "type": "string"
        },
        "help": {
          "type": "string",
          "description": "Short help text shown under the field."
        }
      }
    }
  }
}
